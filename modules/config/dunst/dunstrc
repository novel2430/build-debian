[experimental]
per_monitor_dpi=no

[global]
alignment="left"
always_run_script=yes
browser="xdg-open"
class="Dunst"
corner_radius=0
dmenu="rofi -dmenu"
ellipsize="middle"
follow="mouse"
font="Hack Nerd Font 12"
force_xinerama=no
force_xwayland=no
format="<b>[%a] %s</b>\n%b"
frame_color="#eceff4"
frame_width=3
gap_size=0
height=500
hide_duplicate_count=no
history_length=20
horizontal_padding=8
icon_corner_radius=0
icon_position="left"
ignore_dbusclose=no
ignore_newline=no
indicate_hidden=yes
line_height=0
markup="full"
monitor=0
mouse_left_click="close_current"
mouse_middle_click="do_action, close_current"
mouse_right_click="do_action, close_current"
notification_limit=20
offset="0x20"
origin="top-right"
padding=8
progress_bar=yes
progress_bar_corner_radius=0
progress_bar_frame_width=1
progress_bar_height=10
progress_bar_max_width=300
progress_bar_min_width=150
scale=0
separator_color="frame"
separator_height=2
show_age_threshold=60
show_indicators=yes
sort=yes
stack_duplicates=yes
sticky_history=yes
text_icon_padding=0
title="Dunst"
transparency=0
vertical_alignment="center"
width=350

[history_ignore]
appname="ChangeVolume"
history_ignore=yes

[urgency_critical]
background="#bf616a"
foreground="#eceff4"
frame_color="#eceff4"
highlight="#eceff4"
timeout=0

[urgency_low]
background="#3e5f44"
foreground="#eceff4"
highlight="#eceff4"
timeout=7

[urgency_normal]
background="#3e5f44"
foreground="#eceff4"
highlight="#eceff4"
timeout=7

